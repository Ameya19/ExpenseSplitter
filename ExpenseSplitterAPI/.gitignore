# Build outputs
bin/
obj/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# Rider
.idea/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Sensitive config files — NEVER commit these
appsettings.Development.json
appsettings.Production.json

# But DO commit the base appsettings.json
# (with no real secrets — just placeholders)
!appsettings.json

# EF Core Migrations (optional — most projects commit these)
# Uncomment if you don't want to commit migrations
# **/Migrations/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Docker
# Uncomment if not committing docker files
# docker-compose.override.yml

# Publish output
publish/
**/publish/

# Temporary files
*.tmp
*.temp
~$*